---
import CardShell from "./CardShell.astro";

interface Props {
  title: string;
  marks?: string;
  class?: string;
}

const { title, marks, class: className } = Astro.props;
---

<CardShell title={title} dataCard="exam-practice" class={className}>
  {marks && <p class="lesson-card-tag">{marks}</p>}
  <slot />
</CardShell>
