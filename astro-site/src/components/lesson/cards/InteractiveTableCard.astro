---
import CardShell from "./CardShell.astro";

interface Props {
  title: string;
  class?: string;
}

const { title, class: className } = Astro.props;
const cardClass = ["interactive-table-card", className].filter(Boolean).join(" ");
---

<CardShell title={title} dataCard="interactive-table" class={cardClass}>
  <slot />
</CardShell>
