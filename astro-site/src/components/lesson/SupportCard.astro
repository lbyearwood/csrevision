---
import type { CardVariant } from "../../lib/lessonTypes";

interface Props {
  title: string;
  prompt: string;
  variant?: CardVariant;
}

const { title, prompt, variant = "support" } = Astro.props;
---

<aside class="panel-card lesson-support-card" data-variant={variant}>
  <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
    <span class="grid h-14 w-14 shrink-0 place-items-center rounded-full bg-[var(--color-primary)] text-2xl font-black text-white">?</span>
    <div>
      <h3 class="text-2xl font-black text-[var(--color-primary)]">{title}</h3>
      <p class="mt-3 text-lg font-black leading-7 text-slate-950">{prompt}</p>
      <div class="mt-3 text-base leading-7 text-slate-700">
        <slot />
      </div>
    </div>
  </div>
</aside>
