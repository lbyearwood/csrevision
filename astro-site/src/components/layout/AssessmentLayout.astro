---
import SiteLayout from "./SiteLayout.astro";
import ArrowLeftIcon from "../icons/ArrowLeftIcon.astro";

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  backHref: string;
  backLabel: string;
}

const { title, description, eyebrow, backHref, backLabel } = Astro.props;
---

<SiteLayout title={`${title} | CS Revision`} description={description}>
  <header class="border-b border-blue-100 bg-white">
    <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-6 sm:px-6 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-[var(--color-primary)]">{eyebrow}</p>
        <h1 class="mt-2 text-3xl font-black text-slate-950 sm:text-4xl">{title}</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">{description}</p>
      </div>
      <a href={backHref} class="assessment-secondary-button shrink-0 gap-2">
        <ArrowLeftIcon />
        <span>{backLabel}</span>
      </a>
    </div>
  </header>
  <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <slot />
  </main>
</SiteLayout>
