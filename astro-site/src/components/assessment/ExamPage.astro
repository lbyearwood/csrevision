---
import AssessmentLayout from "../layout/AssessmentLayout.astro";
import { routes } from "../../data/routes";
import type { ExamQuestion } from "../../data/cpuArchitectureAssessments";

interface Props {
  exam: {
    eyebrow: string;
    title: string;
    description: string;
    questions: ExamQuestion[];
  };
}

const { exam } = Astro.props;
---

<AssessmentLayout
  title={exam.title}
  description={exam.description}
  eyebrow={exam.eyebrow}
  backHref={routes.gcse}
  backLabel="Back to topics"
>
  <section class="grid gap-4" aria-label={exam.title}>
    {exam.questions.map((question, index) => {
      const markSchemeId = `mark-scheme-${index + 1}`;

      return (
        <article class="assessment-card">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <p class="text-lg font-bold leading-8 text-slate-950">
              <span class="font-black">{index + 1})</span> {question.question}
            </p>
            <span class="assessment-mark-badge">{question.marks} {question.marks === 1 ? "mark" : "marks"}</span>
          </div>
          <button
            class="assessment-secondary-button mt-5"
            type="button"
            aria-expanded="false"
            aria-controls={markSchemeId}
            data-reveal-button
          >
            Show mark scheme
          </button>
          <div id={markSchemeId} class="assessment-reveal-panel mt-5" hidden>
            <h2 class="text-xl font-black text-[var(--color-primary)]">Mark scheme</h2>
            {question.intro && <p class="mt-3 text-base leading-7 text-slate-700">{question.intro}</p>}
            {question.bands && (
              <div class="assessment-table-wrap mt-4">
                <table class="assessment-table">
                  <thead>
                    <tr>
                      <th scope="col">Mark range</th>
                      <th scope="col">Quality of response</th>
                      <th scope="col">Expected content</th>
                    </tr>
                  </thead>
                  <tbody>
                    {question.bands.map((band) => (
                      <tr>
                        <td>{band.range}</td>
                        <td>{band.quality}</td>
                        <td>{band.content}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
            <ul class="mt-4 grid gap-2 text-base leading-7 text-slate-700">
              {question.markScheme.map((point) => <li>{point}</li>)}
            </ul>
          </div>
        </article>
      );
    })}
  </section>
</AssessmentLayout>

<script>
  document.querySelectorAll("[data-reveal-button]").forEach((button) => {
    button.addEventListener("click", () => {
      const panelId = button.getAttribute("aria-controls");
      const panel = panelId ? document.getElementById(panelId) : null;

      if (!panel) return;

      const isExpanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isExpanded));
      button.textContent = isExpanded ? "Show mark scheme" : "Hide mark scheme";
      panel.hidden = isExpanded;
    });
  });
</script>
