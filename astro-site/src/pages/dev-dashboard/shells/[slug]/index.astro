---
import LessonLayout from "../../../../components/layout/LessonLayout.astro";
import LessonSlideShell from "../../../../components/lesson/LessonSlideShell.astro";
import LessonSideNav from "../../../../components/navigation/LessonSideNav.astro";
import { devShellDefinitions, type DevShellDefinition } from "../../../../data/devShells";
import { routes } from "../../../../data/routes";

interface Props {
  shell: DevShellDefinition;
}

export function getStaticPaths() {
  return devShellDefinitions.map((shell) => ({
    params: { slug: shell.slug },
    props: { shell },
  }));
}

const { shell } = Astro.props;
const shellNumber = devShellDefinitions.findIndex((definition) => definition.slug === shell.slug) + 1;
const numberedShellTitle = `${shellNumber}. ${shell.title}`;
const navSections = [
  { id: "brief", title: "Brief" },
  { id: "example", title: "Example" },
];
---

<LessonLayout
  title={numberedShellTitle}
  courseTitle="Reusable modules"
  breadcrumb={["Shells", numberedShellTitle]}
  backHref={routes.devDashboard}
  backLabel="Back to Dev dashboard"
>
  <div class="lesson-shell">
    <LessonSideNav title={numberedShellTitle} sections={navSections} />
    <main class="lesson-main min-w-0 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <LessonSlideShell id="brief" label={shell.label} heading="Brief" slideNumber={1}>
          <div class="dev-layout-review-panel">
            <h3>{numberedShellTitle}</h3>
            <p>{shell.brief}</p>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="example" label={shell.label} heading="Example" slideNumber={2}>
          <div class="lesson-shell-demo-grid">
            <article class="lesson-shell-demo-block">
              <h3>The shell owns</h3>
              <ul>
                <li>the numbered slide title</li>
                <li>the section ID and scroll target</li>
                <li>the label and heading position</li>
                <li>the slide canvas spacing</li>
              </ul>
            </article>
            <article class="lesson-shell-demo-block">
              <h3>The shell does not own</h3>
              <ul>
                <li>the 2 by 2 card layout inside the slide</li>
                <li>the cards used by that layout</li>
                <li>the topic-specific lesson content</li>
                <li>the activity, model or diagram behaviour</li>
              </ul>
            </article>
          </div>
        </LessonSlideShell>
      </div>
    </main>
  </div>
</LessonLayout>

