---
import LessonLayout from "../../../../components/layout/LessonLayout.astro";
import LessonSlideShell from "../../../../components/lesson/LessonSlideShell.astro";
import ExplanationCard from "../../../../components/lesson/cards/ExplanationCard.astro";
import SupportCard from "../../../../components/lesson/cards/SupportCard.astro";
import TwoColumnTeachingWithSupportLayout from "../../../../components/lesson/layouts/TwoColumnTeachingWithSupportLayout.astro";
import LessonSideNav from "../../../../components/navigation/LessonSideNav.astro";
import { routes } from "../../../../data/routes";

const navSections = [
  { id: "purpose", title: "Purpose" },
  { id: "example", title: "Example" },
];

// Developer review notes for future Codex work:
// - Keep this page to two visible slides: Purpose and Example.
// - Do not render review checks or implementation notes as visible UI.
// - The example should check balanced desktop columns, full-width support beneath,
//   tablet/mobile stacking order, and no horizontal scrolling.
// - Approve the whole-slide arrangement separately from final card designs.
---

<LessonLayout
  title="Two-column teaching with support"
  courseTitle="Reusable modules"
  breadcrumb={["Layouts", "Two-column teaching with support"]}
  backHref={routes.devDashboard}
  backLabel="Back to Dev dashboard"
>
  <div class="lesson-shell">
    <LessonSideNav title="Two-column teaching with support" sections={navSections} />
    <main class="lesson-main min-w-0 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <LessonSlideShell id="purpose" label="Two-column" heading="Purpose" slideNumber={1}>
          <div class="dev-layout-review-panel">
            <h3>Two-column teaching with support</h3>
            <p>Two balanced main areas with a full-width support area underneath.</p>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="example" label="Two-column" heading="Example" slideNumber={2}>
          <TwoColumnTeachingWithSupportLayout>
            <ExplanationCard slot="left" title="Left main area">
              <p>
                This area carries the first major teaching block. It is usually where the idea is introduced,
                explained or set up before a visual, model or activity is used.
              </p>
              <p>
                It should feel balanced with the right area, not like a small note beside the main lesson.
                If the explanation needs lots of detail, use a different slide layout.
              </p>
            </ExplanationCard>
            <ExplanationCard slot="right" title="Right main area">
              <p>
                This area carries the second major teaching block. It can extend the explanation, present a
                comparison, or introduce the visual model that makes the idea clearer.
              </p>
              <p>
                It should connect directly to the left area so both cards read as one teaching moment, not
                as two unrelated panels.
              </p>
              <ul>
                <li>carries the second major teaching block</li>
                <li>often holds a visual, model, comparison or activity</li>
                <li>must not feel like a thin side note</li>
              </ul>
            </ExplanationCard>
            <SupportCard slot="support" title="Full-width support area">
              <p>Completes the slide with a check, reinforcement prompt or short extension across the full teaching width.</p>
            </SupportCard>
          </TwoColumnTeachingWithSupportLayout>
        </LessonSlideShell>
      </div>
    </main>
  </div>
</LessonLayout>
