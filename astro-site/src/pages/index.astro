---
import SiteLayout from "../components/layout/SiteLayout.astro";
import ArrowRightIcon from "../components/icons/ArrowRightIcon.astro";
import MainNav from "../components/navigation/MainNav.astro";
import { courseCards } from "../data/courses";
---

<SiteLayout title="CS Revision" description="Computer Science and ICT revision lessons.">
  <MainNav />
  <main class="mx-auto content-measure px-4 py-8 sm:px-6 lg:px-8">
    <section class="max-w-3xl">
      <div>
        <p class="text-sm font-black uppercase tracking-wide text-[var(--color-primary)]">Computer Science and ICT</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-black leading-tight text-slate-950 sm:text-5xl">
          Clear revision lessons for confident exam preparation.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
          Choose a course to revise key topics with explanations, diagrams and practice prompts.
        </p>
      </div>
    </section>

    <section class="mt-10 grid gap-4 md:grid-cols-2">
      {courseCards.map((course) => (
        <a href={course.href} class="panel-card flex min-h-56 flex-col justify-between p-6 transition hover:-translate-y-0.5 hover:border-blue-300">
          <div>
            <h2 class="text-2xl font-black text-slate-950">{course.title}</h2>
            <p class="mt-3 text-base leading-7 text-slate-700">{course.description}</p>
          </div>
          <span class="mt-6 inline-flex items-center gap-2 text-sm font-black text-[var(--color-primary)]">
            <span>Open course</span>
            <ArrowRightIcon />
          </span>
        </a>
      ))}
    </section>
  </main>
</SiteLayout>
