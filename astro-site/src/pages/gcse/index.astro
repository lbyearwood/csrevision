---
import DashboardLayout from "../../components/layout/DashboardLayout.astro";
import TopicCard from "../../components/dashboard/TopicCard.astro";
import { gcseDashboard } from "../../data/courses";
---

<DashboardLayout title={gcseDashboard.title} description={gcseDashboard.description}>
  <section class="mb-8 max-w-3xl">
    <h1 class="text-3xl font-black text-slate-950 sm:text-4xl">{gcseDashboard.title}</h1>
    <p class="mt-3 text-lg leading-8 text-slate-700">{gcseDashboard.description}</p>
  </section>

  <div id="topics" class="grid gap-6">
    {gcseDashboard.topicGroups.map((paper) => (
      <section class="dashboard-card p-5 sm:p-6" aria-labelledby={`${paper.paper.toLowerCase().replace(" ", "-")}-heading`}>
        <h2 id={`${paper.paper.toLowerCase().replace(" ", "-")}-heading`} class="text-2xl font-black text-slate-950">
          {paper.paper}
        </h2>
        <div class="mt-5 grid gap-5">
          {paper.groups.map((group) => (
            <section aria-labelledby={`${group.heading.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}-heading`}>
              <h3 id={`${group.heading.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}-heading`} class="mb-3 text-lg font-black text-slate-900">
                {group.heading}
              </h3>
              <div class="grid gap-3">
                {group.topics.map((topic) => (
                  <TopicCard
                    code={topic.code}
                    title={topic.title}
                    resources={topic.resources}
                  />
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    ))}
  </div>
</DashboardLayout>
