---
import LessonLayout from "../../../../components/layout/LessonLayout.astro";
import LessonSideNav from "../../../../components/navigation/LessonSideNav.astro";
import LessonSlideShell from "../../../../components/lesson/LessonSlideShell.astro";
import ExplanationCard from "../../../../components/lesson/cards/ExplanationCard.astro";
import HingeQuestionCard from "../../../../components/lesson/cards/HingeQuestionCard.astro";
import LearningObjectivesCard from "../../../../components/lesson/cards/LearningObjectivesCard.astro";
import MisconceptionCard from "../../../../components/lesson/cards/MisconceptionCard.astro";
import ModellingCard from "../../../../components/lesson/cards/ModellingCard.astro";
import PromptCard from "../../../../components/lesson/cards/PromptCard.astro";
import QuestionCard from "../../../../components/lesson/cards/QuestionCard.astro";
import SupportCard from "../../../../components/lesson/cards/SupportCard.astro";
import FeedbackState from "../../../../components/lesson/components/FeedbackState.astro";
import LabelBadge from "../../../../components/lesson/components/LabelBadge.astro";
import MultipleChoiceOption from "../../../../components/lesson/components/MultipleChoiceOption.astro";
import NextButton from "../../../../components/lesson/components/NextButton.astro";
import PreviousButton from "../../../../components/lesson/components/PreviousButton.astro";
import ResetButton from "../../../../components/lesson/components/ResetButton.astro";

const lessonTitle = "1.1.2 CPU performance";
const navSections = [
  { id: "cpu-performance-title", title: "CPU performance" },
  { id: "upgrade-challenge", title: "Upgrade challenge" },
  { id: "learning-objectives", title: "Learning objectives" },
  { id: "performance-factors", title: "Three factors" },
  { id: "clock-speed-cycles", title: "Clock speed" },
  { id: "clock-speed-instructions", title: "More instructions" },
];
---

<LessonLayout
  title={lessonTitle}
  courseTitle="OCR GCSE Computer Science"
  breadcrumb={["GCSE", "Computer systems", "1.1 Systems architecture", lessonTitle]}
  backHref="/gcse/"
  backLabel="Back to GCSE topics"
>
  <div class="lesson-shell cpu-performance-lesson">
    <LessonSideNav title={lessonTitle} sections={navSections} />
    <main class="lesson-main min-w-0 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <LessonSlideShell id="cpu-performance-title" label="Lesson" heading="CPU Performance" slideNumber={1}>
          <section class="cpu-title-slide" aria-label="CPU performance lesson introduction">
            <p class="cpu-title-kicker">1.1.2 Systems architecture</p>
            <h2>CPU performance</h2>
            <p>
              A faster CPU is not just the biggest number on the advert. The best upgrade depends on the
              task the computer is trying to complete.
            </p>
          </section>
        </LessonSlideShell>

        <LessonSlideShell id="upgrade-challenge" label="Hook" heading="Upgrade Challenge" slideNumber={2}>
          <div class="cpu-layout-two-top-wide-bottom">
            <PromptCard title="Upgrade advert A">
              <p class="cpu-upgrade-value">Higher GHz</p>
              <p>More clock cycles can happen each second.</p>
            </PromptCard>
            <PromptCard title="Upgrade advert B">
              <p class="cpu-upgrade-value">More cores</p>
              <p>More processing units can share suitable work.</p>
            </PromptCard>
            <QuestionCard title="First prediction">
              <p>
                Which upgrade would you choose for a single calculation-heavy program, and which would you choose
                when several applications are open at the same time?
              </p>
              <p class="cpu-teacher-note">Keep your prediction. We will come back to it after the clock speed model.</p>
            </QuestionCard>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="learning-objectives" label="Objectives" heading="Learning Objectives" slideNumber={3}>
          <div class="cpu-layout-full">
            <LearningObjectivesCard title="By the end of this lesson you will be able to">
              <ol>
                <li>Define clock speed, cache size and number of cores.</li>
                <li>Explain how each characteristic can affect CPU performance.</li>
                <li>Choose the most relevant CPU characteristic for a given scenario.</li>
                <li>Explain why one CPU upgrade does not always guarantee better performance.</li>
              </ol>
            </LearningObjectivesCard>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="performance-factors" label="Overview" heading="The Three CPU Performance Factors" slideNumber={4}>
          <div class="cpu-layout-four-equal">
            <ExplanationCard title="Clock speed">
              <p>The number of cycles the CPU can carry out each second.</p>
              <p><LabelBadge>Measured in GHz</LabelBadge></p>
            </ExplanationCard>
            <ExplanationCard title="Cache size">
              <p>The amount of fast memory close to the CPU for frequently used data and instructions.</p>
              <p><LabelBadge>Reduces waiting</LabelBadge></p>
            </ExplanationCard>
            <ExplanationCard title="Number of cores">
              <p>The number of processing units inside the CPU.</p>
              <p><LabelBadge>Can help multitasking</LabelBadge></p>
            </ExplanationCard>
            <SupportCard title="Important idea">
              <p>The best characteristic depends on the task, the software and the other CPU characteristics.</p>
            </SupportCard>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-cycles" label="Part 1" heading="Clock Speed Means Cycles Per Second" slideNumber={5}>
          <div class="cpu-layout-two-vertical">
            <ExplanationCard title="What clock speed measures">
              <p>
                Clock speed is the number of CPU cycles that can happen each second. It is commonly measured
                in gigahertz, written as <strong>GHz</strong>.
              </p>
              <ul>
                <li><strong>1 GHz</strong> means about one billion cycles per second.</li>
                <li><strong>3 GHz</strong> means about three billion cycles per second.</li>
                <li>A cycle is a tiny timing pulse used while the CPU works through instructions.</li>
              </ul>
            </ExplanationCard>

            <ExplanationCard title="Lower speed vs higher speed">
              <div class="cpu-cycle-compare" aria-label="Clock speed comparison">
                <article>
                  <h4>1 GHz</h4>
                  <div class="cpu-cycle-row" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <p>Fewer cycles in the same time.</p>
                </article>
                <article>
                  <h4>3 GHz</h4>
                  <div class="cpu-cycle-row cpu-cycle-row--fast" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <p>More cycles in the same time.</p>
                </article>
              </div>
              <FeedbackState tone="neutral">
                A higher GHz value means more CPU cycles can happen per second.
              </FeedbackState>
            </ExplanationCard>
          </div>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-instructions" label="Part 1" heading="Faster Clock Speed Can Process More Instructions" slideNumber={6}>
          <div class="cpu-layout-tall-left-two-right">
            <ModellingCard title="Instruction throughput model" class="cpu-clock-model">
              <p class="cpu-model-intro">
                Step through the same one-second window and compare how many simple instructions each CPU can work through.
              </p>
              <div class="cpu-model-stage" data-clock-model aria-live="polite">
                <div class="cpu-model-lane">
                  <h4>Lower clock speed</h4>
                  <div class="cpu-instruction-track" data-lane="slow">
                    <span class="is-active">Fetch</span>
                    <span>Decode</span>
                    <span>Execute</span>
                    <span>Write back</span>
                  </div>
                  <p data-slow-status>Step 1: one instruction has started.</p>
                </div>
                <div class="cpu-model-lane cpu-model-lane--fast">
                  <h4>Higher clock speed</h4>
                  <div class="cpu-instruction-track" data-lane="fast">
                    <span class="is-active">Fetch</span>
                    <span>Decode</span>
                    <span>Execute</span>
                    <span>Write back</span>
                    <span>Fetch</span>
                    <span>Decode</span>
                    <span>Execute</span>
                    <span>Write back</span>
                  </div>
                  <p data-fast-status>Step 1: a second instruction can begin sooner.</p>
                </div>
              </div>
              <div class="cpu-model-controls" data-clock-controls>
                <PreviousButton data-action="previous">Previous step</PreviousButton>
                <NextButton data-action="next">Next step</NextButton>
                <ResetButton data-action="reset">Reset</ResetButton>
              </div>
              <FeedbackState tone="neutral" data-clock-summary>
                Step 1 of 4: both CPUs begin work, but the higher clock speed has more timing pulses available.
              </FeedbackState>
            </ModellingCard>

            <SupportCard title="Why this can improve performance">
              <p>
                More cycles per second can allow more instructions to be processed per second. This can improve
                performance for tasks that rely on fast sequential processing, such as repeated calculations.
              </p>
            </SupportCard>

            <MisconceptionCard title="Misconception">
              <div class="cpu-misconception-grid">
                <FeedbackState tone="incorrect">
                  Higher clock speed always makes every task faster.
                </FeedbackState>
                <FeedbackState tone="correct">
                  Higher clock speed can help, but performance also depends on cache, cores, software and the task.
                </FeedbackState>
              </div>
            </MisconceptionCard>
          </div>

          <div class="cpu-hinge-row">
            <HingeQuestionCard title="Which task is most likely to benefit from higher clock speed?" class="lesson-card-hinge-question">
              <p class="lesson-card-hinge-prompt">
                Choose the task where faster sequential instruction processing is likely to matter most.
              </p>
              <ol class="lesson-card-option-list" data-single-choice data-feedback-target="clock-hinge-feedback" type="A">
                <li>
                  <MultipleChoiceOption variant="lesson" data-feedback="A higher clock speed is useful for repeated calculations because more cycles can allow more instructions to be processed each second.">
                    A program performing many calculations one after another
                  </MultipleChoiceOption>
                </li>
                <li>
                  <MultipleChoiceOption variant="lesson" data-feedback="Running several applications at once is usually more directly linked to the number of cores.">
                    Browser, presentation software and antivirus all running at the same time
                  </MultipleChoiceOption>
                </li>
                <li data-correct="true">
                  <MultipleChoiceOption variant="lesson" data-feedback="Correct. A calculation-heavy task is a good example because faster cycles can help the CPU work through instructions more quickly.">
                    A single calculation-heavy program
                  </MultipleChoiceOption>
                </li>
                <li>
                  <MultipleChoiceOption variant="lesson" data-feedback="Repeated data often points towards cache because useful data can be kept close to the CPU.">
                    A program repeatedly using the same image data
                  </MultipleChoiceOption>
                </li>
              </ol>
              <FeedbackState id="clock-hinge-feedback" class="lesson-card-hinge-feedback" aria-live="polite">
                Select an answer to check whether the clock speed idea is secure.
              </FeedbackState>
              <div class="lesson-card-choice-actions">
                <ResetButton data-reset-choice>Reset</ResetButton>
              </div>
            </HingeQuestionCard>
          </div>
        </LessonSlideShell>
      </div>
    </main>
  </div>
</LessonLayout>

<script>
  const clockSteps = [
    {
      slow: "Step 1: one instruction has started.",
      fast: "Step 1: a second instruction can begin sooner.",
      summary: "Step 1 of 4: both CPUs begin work, but the higher clock speed has more timing pulses available.",
      slowCount: 1,
      fastCount: 1,
    },
    {
      slow: "Step 2: the lower-speed CPU is still working through the first instruction.",
      fast: "Step 2: the higher-speed CPU has already moved further through the queue.",
      summary: "Step 2 of 4: more cycles per second means the instruction queue can move faster.",
      slowCount: 2,
      fastCount: 3,
    },
    {
      slow: "Step 3: fewer instructions have been processed in the same second.",
      fast: "Step 3: more instruction stages have completed in the same second.",
      summary: "Step 3 of 4: higher clock speed can allow more instructions to be processed per second.",
      slowCount: 3,
      fastCount: 6,
    },
    {
      slow: "Step 4: the lower-speed CPU completes fewer stages in this model.",
      fast: "Step 4: the higher-speed CPU completes more stages in this model.",
      summary: "Step 4 of 4: clock speed can improve performance, especially for fast sequential processing.",
      slowCount: 4,
      fastCount: 8,
    },
  ];

  const clockModel = document.querySelector("[data-clock-model]");
  const clockControls = document.querySelector("[data-clock-controls]");
  const clockSummary = document.querySelector("[data-clock-summary]");
  let clockStep = 0;

  const setClockStep = (stepIndex) => {
    if (!(clockModel instanceof HTMLElement) || !(clockSummary instanceof HTMLElement)) {
      return;
    }

    clockStep = Math.max(0, Math.min(clockSteps.length - 1, stepIndex));
    const step = clockSteps[clockStep];
    const slowStatus = clockModel.querySelector("[data-slow-status]");
    const fastStatus = clockModel.querySelector("[data-fast-status]");
    const slowNodes = Array.from(clockModel.querySelectorAll('[data-lane="slow"] span'));
    const fastNodes = Array.from(clockModel.querySelectorAll('[data-lane="fast"] span'));

    if (slowStatus) {
      slowStatus.textContent = step.slow;
    }

    if (fastStatus) {
      fastStatus.textContent = step.fast;
    }

    slowNodes.forEach((node, index) => node.classList.toggle("is-active", index < step.slowCount));
    fastNodes.forEach((node, index) => node.classList.toggle("is-active", index < step.fastCount));
    clockSummary.textContent = step.summary;
  };

  clockControls?.addEventListener("click", (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest("button") : null;
    const action = target?.getAttribute("data-action");

    if (action === "previous") {
      setClockStep(clockStep - 1);
    }

    if (action === "next") {
      setClockStep(clockStep + 1);
    }

    if (action === "reset") {
      setClockStep(0);
    }
  });

  document.querySelectorAll("[data-single-choice]").forEach((choiceList) => {
    choiceList.addEventListener("click", (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest("button") : null;
      const option = button?.closest("li");

      if (!(option instanceof HTMLElement)) {
        return;
      }

      const feedbackTarget = choiceList.getAttribute("data-feedback-target");
      const feedback = feedbackTarget ? document.getElementById(feedbackTarget) : null;
      const isCorrect = option.hasAttribute("data-correct");

      choiceList.querySelectorAll("li").forEach((item) => item.classList.remove("is-correct", "is-incorrect"));
      option.classList.add(isCorrect ? "is-correct" : "is-incorrect");

      if (feedback) {
        feedback.textContent = button?.getAttribute("data-feedback") ?? "";
        feedback.classList.toggle("dev-component-feedback--correct", isCorrect);
        feedback.classList.toggle("dev-component-feedback--incorrect", !isCorrect);
      }
    });
  });

  document.querySelectorAll("[data-reset-choice]").forEach((button) => {
    button.addEventListener("click", () => {
      const card = button.closest(".lesson-card-module");
      card?.querySelectorAll("[data-single-choice] li").forEach((option) => {
        option.classList.remove("is-correct", "is-incorrect");
      });

      const feedback = card?.querySelector(".lesson-card-hinge-feedback");

      if (feedback) {
        feedback.textContent = "Select an answer to check whether the clock speed idea is secure.";
        feedback.classList.remove("dev-component-feedback--correct", "dev-component-feedback--incorrect");
      }
    });
  });

  setClockStep(0);
</script>

<style>
  .cpu-performance-lesson .lesson-card-module {
    min-height: 100%;
  }

  .cpu-performance-lesson .lesson-section-heading {
    overflow-wrap: anywhere;
    text-align: center;
  }

  .cpu-title-slide {
    display: grid;
    box-sizing: border-box;
    width: 100%;
    min-width: 0;
    min-height: clamp(28rem, 62vh, 40rem);
    align-content: center;
    justify-items: center;
    gap: 1rem;
    border: 1px solid #bfdbfe;
    border-radius: var(--radius-card);
    background:
      linear-gradient(#dbeafe 1px, transparent 1px),
      linear-gradient(90deg, #dbeafe 1px, transparent 1px),
      #ffffff;
    background-size: 3rem 3rem;
    padding: clamp(2rem, 5vw, 4rem);
    text-align: center;
  }

  .cpu-title-slide > * {
    max-width: 100%;
    min-width: 0;
  }

  .cpu-title-kicker {
    margin: 0;
    color: var(--color-primary);
    font-weight: 900;
  }

  .cpu-title-slide h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 0.98;
  }

  .cpu-title-slide p:last-child {
    max-width: 52rem;
    margin: 0;
    color: #334155;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 800;
    line-height: 1.45;
  }

  .cpu-layout-full,
  .cpu-layout-two-vertical,
  .cpu-layout-two-top-wide-bottom,
  .cpu-layout-four-equal,
  .cpu-layout-tall-left-two-right {
    display: grid;
    gap: clamp(1rem, 2vw, 1.25rem);
    margin-top: clamp(1rem, 1.8vh, 1.375rem);
  }

  .cpu-layout-two-vertical {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cpu-layout-two-top-wide-bottom {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cpu-layout-two-top-wide-bottom > :last-child {
    grid-column: 1 / -1;
  }

  .cpu-layout-four-equal {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cpu-layout-tall-left-two-right {
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.8fr);
    grid-template-rows: repeat(2, minmax(0, auto));
  }

  .cpu-layout-tall-left-two-right > :first-child {
    grid-row: 1 / span 2;
  }

  .cpu-hinge-row {
    margin-top: clamp(1rem, 2vw, 1.25rem);
  }

  .cpu-upgrade-value {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1;
  }

  .cpu-teacher-note {
    border-left: 6px solid var(--color-primary);
    border-radius: var(--radius-card);
    background: var(--color-primary-soft);
    padding: 0.9rem 1rem;
    color: #0f172a;
    font-weight: 800;
  }

  .cpu-cycle-compare {
    display: grid;
    gap: 1rem;
  }

  .cpu-cycle-compare article {
    border: 1px solid #bfdbfe;
    border-radius: var(--radius-card);
    background: #f8fbff;
    padding: 1rem;
  }

  .cpu-cycle-compare h4,
  .cpu-model-lane h4 {
    margin: 0 0 0.75rem;
    color: #0f172a;
    font-size: 1.1rem;
    font-weight: 900;
  }

  .cpu-cycle-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .cpu-cycle-row--fast {
    grid-template-columns: repeat(9, minmax(0, 1fr));
  }

  .cpu-cycle-row span {
    display: block;
    min-height: 2.5rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .cpu-clock-model .lesson-card-module-body {
    display: grid;
    gap: 1rem;
  }

  .cpu-model-intro {
    margin: 0;
    text-align: center;
  }

  .cpu-model-stage {
    display: grid;
    gap: 1rem;
  }

  .cpu-model-lane {
    border: 1px solid #bfdbfe;
    border-radius: var(--radius-card);
    background: #f8fbff;
    padding: 1rem;
  }

  .cpu-model-lane--fast {
    border-color: #93c5fd;
    background: #eff6ff;
  }

  .cpu-instruction-track {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .cpu-model-lane--fast .cpu-instruction-track {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .cpu-instruction-track span {
    display: grid;
    min-height: 3rem;
    place-items: center;
    border: 2px solid #bfdbfe;
    border-radius: var(--radius-card);
    background: #ffffff;
    color: #1e3a8a;
    font-size: 0.9rem;
    font-weight: 900;
    text-align: center;
  }

  .cpu-instruction-track span.is-active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #ffffff;
  }

  .cpu-model-controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .cpu-misconception-grid {
    display: grid;
    gap: 0.8rem;
  }

  @media (max-width: 64rem) {
    .cpu-layout-two-vertical,
    .cpu-layout-two-top-wide-bottom,
    .cpu-layout-four-equal,
    .cpu-layout-tall-left-two-right {
      grid-template-columns: 1fr;
    }

    .cpu-layout-two-top-wide-bottom > :last-child,
    .cpu-layout-tall-left-two-right > :first-child {
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (max-width: 40rem) {
    .cpu-performance-lesson .lesson-section-heading {
      font-size: clamp(1.75rem, 8vw, 2.35rem);
      line-height: 1.08;
    }

    .cpu-title-slide {
      min-height: 26rem;
      background-size: 2rem 2rem;
    }

    .cpu-title-slide h2 {
      font-size: clamp(2rem, 10vw, 2.45rem);
      overflow-wrap: anywhere;
    }

    .cpu-title-slide p:last-child {
      font-size: 1.05rem;
      line-height: 1.42;
    }

    .cpu-cycle-row,
    .cpu-cycle-row--fast {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .cpu-instruction-track,
    .cpu-model-lane--fast .cpu-instruction-track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
