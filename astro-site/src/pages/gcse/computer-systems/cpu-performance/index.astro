---
import LessonLayout from "../../../../components/layout/LessonLayout.astro";
import LessonSideNav from "../../../../components/navigation/LessonSideNav.astro";
import LessonSlideShell from "../../../../components/lesson/LessonSlideShell.astro";
import ExplanationCard from "../../../../components/lesson/cards/ExplanationCard.astro";
import ImageCard from "../../../../components/lesson/cards/ImageCard.astro";
import LearningObjectivesCard from "../../../../components/lesson/cards/LearningObjectivesCard.astro";
import QuestionCard from "../../../../components/lesson/cards/QuestionCard.astro";
import SingleMultipleChoiceCard from "../../../../components/lesson/cards/SingleMultipleChoiceCard.astro";
import FeedbackState from "../../../../components/lesson/components/FeedbackState.astro";
import CommandWord from "../../../../components/lesson/components/CommandWord.astro";
import LearningObjectiveItem from "../../../../components/lesson/components/LearningObjectiveItem.astro";
import MultipleChoiceOption from "../../../../components/lesson/components/MultipleChoiceOption.astro";
import OneFullSpanCard from "../../../../components/lesson/layouts/OneFullSpanCard.astro";
import TitleSegmentSlide from "../../../../components/lesson/layouts/TitleSegmentSlide.astro";
import TwoTopCardsWideBottomCard from "../../../../components/lesson/layouts/TwoTopCardsWideBottomCard.astro";
import TwoVerticalCards from "../../../../components/lesson/layouts/TwoVerticalCards.astro";
import { assertUniqueLessonPartTitles, type LessonSlideShellLabel } from "../../../../lib/lessonSlideShellLabels";

const lessonTitle = "1.1.2 CPU performance";
const shellLabels = {
  introduction: "Lesson introduction",
  clockSpeed: "Part 1 - Clock speed",
  cacheSize: "Part 2 - Cache size",
  numberOfCores: "Part 3 - Number of cores",
  bestUpgrade: "Part 4 - Choosing the best CPU upgrade",
  summary: "Lesson summary",
} satisfies Record<string, LessonSlideShellLabel>;

assertUniqueLessonPartTitles(Object.values(shellLabels));

const navSections = [
  { id: "cpu-performance-title", title: "CPU performance" },
  { id: "upgrade-challenge", title: "Lesson starter" },
  { id: "learning-objectives", title: "Learning objectives" },
  { id: "performance-factors", title: "CPU factors" },
  { id: "part-1-clock-speed", title: "Part 1 - Clock speed" },
  { id: "clock-speed-cycles", title: "Clock speed (A)" },
  { id: "clock-speed-instructions", title: "Clock speed (B)" },
  { id: "clock-speed-check-measure", title: "Multiple choice (A)" },
  { id: "clock-speed-check-instructions", title: "Multiple choice (B)" },
  { id: "clock-speed-check-limit", title: "Multiple choice (C)" },
];
---

<LessonLayout
  title={lessonTitle}
  courseTitle="OCR GCSE Computer Science"
  breadcrumb={["GCSE", "Computer systems", "1.1 Systems architecture", lessonTitle]}
  backHref="/gcse/"
  backLabel="Back to GCSE topics"
>
  <div class="lesson-shell">
    <LessonSideNav title={lessonTitle} sections={navSections} />
    <main class="lesson-main min-w-0 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <LessonSlideShell id="cpu-performance-title" label={shellLabels.introduction} heading="CPU Performance" slideNumber={1} hideHeader>
          <TitleSegmentSlide
            kind="lesson-title"
            title="1.1.2 CPU performance"
          />
        </LessonSlideShell>

        <LessonSlideShell id="upgrade-challenge" label={shellLabels.introduction} heading="Lesson starter" slideNumber={2}>
          <TwoTopCardsWideBottomCard>
            <ImageCard
              title="Upgrade advert A"
              src="/images/lessons/cpu-performance/upgrade-advert-ghz-openai.png"
              alt="Advert for a 3.8 GHz CPU upgrade showing a speed boost and processor chip."
              caption="Higher GHz means more clock cycles can happen each second."
              class="lesson-card-generated-image"
              slot="top-left"
            />
            <ImageCard
              title="Upgrade advert B"
              src="/images/lessons/cpu-performance/upgrade-advert-cores-openai.png"
              alt="Advert for an eight core CPU upgrade with multitasking app windows"
              caption="More cores can help suitable tasks share work."
              class="lesson-card-generated-image"
              slot="top-right"
            />
            <QuestionCard title="First prediction" slot="bottom">
              <p>
                Which upgrade would you choose for a single calculation-heavy program, and which would you choose
                when several applications are open at the same time?
              </p>
              <FeedbackState tone="neutral">
                Keep your prediction. We will come back to it after the clock speed explanation.
              </FeedbackState>
            </QuestionCard>
          </TwoTopCardsWideBottomCard>
        </LessonSlideShell>

        <LessonSlideShell id="learning-objectives" label={shellLabels.introduction} heading="Learning Objectives" slideNumber={3}>
          <OneFullSpanCard>
            <LearningObjectivesCard title="Learning objectives">
              <p>By the end of this lesson, you should be able to:</p>
              <ol class="lesson-card-objectives-list">
                <LearningObjectiveItem number={1}><CommandWord>Define</CommandWord> clock speed, cache size and number of cores.</LearningObjectiveItem>
                <LearningObjectiveItem number={2}><CommandWord>Explain</CommandWord> how each characteristic can affect CPU performance.</LearningObjectiveItem>
                <LearningObjectiveItem number={3}><CommandWord>Choose</CommandWord> the most relevant CPU characteristic for a given scenario.</LearningObjectiveItem>
                <LearningObjectiveItem number={4}><CommandWord>Explain</CommandWord> why one CPU upgrade does not always guarantee better performance.</LearningObjectiveItem>
              </ol>
            </LearningObjectivesCard>
          </OneFullSpanCard>
        </LessonSlideShell>

        <LessonSlideShell id="performance-factors" label={shellLabels.introduction} heading="What are three factors that impact CPU performance?" slideNumber={4}>
          <TwoTopCardsWideBottomCard>
            <ImageCard
              title="Clock speed"
              src="/images/lessons/cpu-performance/factor-clock-speed-openai.png"
              alt="Clock speed visual card showing fast ticks, clock pulses, a speed gauge and a CPU chip."
              caption="How quickly the CPU can tick through cycles."
              class="lesson-card-generated-image"
              slot="top-left"
            />
            <ImageCard
              title="Cache size"
              src="/images/lessons/cpu-performance/factor-cache-openai.png"
              alt="Cache size visual card showing fast nearby memory blocks around a CPU chip."
              caption="Fast nearby memory can reduce waiting."
              class="lesson-card-generated-image"
              slot="top-right"
            />
            <ImageCard
              title="Number of cores"
              src="/images/lessons/cpu-performance/factor-cores-openai.png"
              alt="Number of cores visual card showing eight cores and task windows sharing work."
              caption="Several cores can share suitable work."
              class="lesson-card-generated-image"
              slot="bottom"
            />
          </TwoTopCardsWideBottomCard>
        </LessonSlideShell>

        <LessonSlideShell id="part-1-clock-speed" label={shellLabels.clockSpeed} heading="Clock Speed" slideNumber={5} hideHeader>
          <TitleSegmentSlide kind="part-title" title={shellLabels.clockSpeed} />
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-cycles" label={shellLabels.clockSpeed} heading="What is clock speed?" slideNumber={6}>
          <TwoVerticalCards>
            <ExplanationCard title="What clock speed measures" slot="left">
              <p>
                Clock speed is the number of CPU cycles that can happen each second. It is commonly measured
                in gigahertz, written as <strong>GHz</strong>.
              </p>
              <ul>
                <li><strong>1 GHz</strong> means about one billion cycles per second.</li>
                <li><strong>3 GHz</strong> means about three billion cycles per second.</li>
                <li>A cycle is a tiny timing pulse used while the CPU works through instructions.</li>
              </ul>
            </ExplanationCard>

            <ImageCard
              title="Cycles per second"
              src="/images/lessons/cpu-performance/clock-speed-pulses-openai.png"
              alt="Cycles per second visual card comparing fewer clock pulses with more clock pulses in the same time."
              caption="Higher GHz means more cycles can happen in the same amount of time."
              class="lesson-card-generated-image"
              slot="right"
            />
          </TwoVerticalCards>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-instructions" label={shellLabels.clockSpeed} heading="How does clock speed affect performance?" slideNumber={7}>
          <TwoVerticalCards>
            <ExplanationCard title="More cycles can mean more instructions" slot="left">
              <p>
                A CPU uses clock cycles to keep its work in time. When the clock speed is higher, more cycles can
                happen each second, so the CPU may be able to process more instructions in the same amount of time.
              </p>
              <ul>
                <li>This can make calculation-heavy tasks finish sooner.</li>
                <li>The benefit is strongest when the task depends on fast sequential processing.</li>
              </ul>
            </ExplanationCard>

            <ImageCard
              title="Instruction throughput diagram"
              src="/images/lessons/cpu-performance/clock-speed-instructions-openai.png"
              alt="One-second comparison showing a lower clock speed with fewer instruction blocks and a higher clock speed with more instruction blocks."
              caption="A higher clock speed can allow more instruction work to happen in the same amount of time."
              class="lesson-card-generated-image"
              slot="right"
            />
          </TwoVerticalCards>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-check-measure" label={shellLabels.clockSpeed} heading="Multiple choice" slideNumber={8}>
          <OneFullSpanCard>
            <SingleMultipleChoiceCard
              question="What does clock speed measure?"
              helperText="Select an answer to check what clock speed measures."
              feedbackId="clock-speed-measure-feedback"
            >
              <li data-correct="true" data-feedback="Correct. Clock speed measures how many CPU cycles can happen each second.">
                <MultipleChoiceOption marker="A" data-choice-option>
                  The number of CPU cycles that can happen each second
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. The CPU stores permanent data elsewhere; clock speed is about cycles per second.">
                <MultipleChoiceOption marker="B" data-choice-option>
                  The amount of data the CPU can store permanently
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Installed programs do not tell you how quickly the CPU clock is ticking.">
                <MultipleChoiceOption marker="C" data-choice-option>
                  The number of programs installed on the computer
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Cache size is a different CPU performance factor.">
                <MultipleChoiceOption marker="D" data-choice-option>
                  The size of the CPU cache
                </MultipleChoiceOption>
              </li>
            </SingleMultipleChoiceCard>
          </OneFullSpanCard>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-check-instructions" label={shellLabels.clockSpeed} heading="Multiple choice" slideNumber={9}>
          <OneFullSpanCard>
            <SingleMultipleChoiceCard
              question="What can a higher clock speed allow a CPU to do?"
              helperText="Select an answer to check how clock speed can affect instruction processing."
              feedbackId="clock-speed-instructions-feedback"
            >
              <li data-feedback="Not quite. Secondary storage capacity is not controlled by the CPU clock speed.">
                <MultipleChoiceOption marker="A" data-choice-option>
                  Store more files on secondary storage
                </MultipleChoiceOption>
              </li>
              <li data-correct="true" data-feedback="Correct. More clock cycles per second can allow more instructions to be processed in the same amount of time.">
                <MultipleChoiceOption marker="B" data-choice-option>
                  Process more instructions in the same amount of time
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Clock speed does not automatically add more CPU cores.">
                <MultipleChoiceOption marker="C" data-choice-option>
                  Automatically add more CPU cores
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Cache can still matter even when clock speed is higher.">
                <MultipleChoiceOption marker="D" data-choice-option>
                  Remove the need for cache memory
                </MultipleChoiceOption>
              </li>
            </SingleMultipleChoiceCard>
          </OneFullSpanCard>
        </LessonSlideShell>

        <LessonSlideShell id="clock-speed-check-limit" label={shellLabels.clockSpeed} heading="Multiple choice" slideNumber={10}>
          <OneFullSpanCard>
            <SingleMultipleChoiceCard
              question="Which statement about clock speed is most accurate?"
              helperText="Select an answer to check the limits of clock speed as a performance factor."
              feedbackId="clock-speed-limit-feedback"
            >
              <li data-feedback="Not quite. Higher clock speed can help, but it does not always make every task faster.">
                <MultipleChoiceOption marker="A" data-choice-option>
                  Higher clock speed always makes every task faster
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Clock speed is about cycles per second, not how much memory a CPU has.">
                <MultipleChoiceOption marker="B" data-choice-option>
                  Clock speed only affects how much memory a CPU has
                </MultipleChoiceOption>
              </li>
              <li data-correct="true" data-feedback="Correct. Higher clock speed can help, but performance also depends on the task, cache, cores and software.">
                <MultipleChoiceOption marker="C" data-choice-option>
                  Higher clock speed can help, but the task and other CPU features still matter
                </MultipleChoiceOption>
              </li>
              <li data-feedback="Not quite. Many applications at once points more directly towards cores, not only clock speed.">
                <MultipleChoiceOption marker="D" data-choice-option>
                  Clock speed is useful only when many applications run at once
                </MultipleChoiceOption>
              </li>
            </SingleMultipleChoiceCard>
          </OneFullSpanCard>
        </LessonSlideShell>
      </div>
    </main>
  </div>
</LessonLayout>

